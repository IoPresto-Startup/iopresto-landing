# EmailJS — https://www.emailjs.com/
# 1. Registrati su emailjs.com (gratuito, 200 email/mese)
# 2. Crea un Service (es. Gmail) e copia il Service ID
# 3. Crea DUE template:
#    - template TEST  → "To email" = tua email personale  (usato localmente)
#    - template PROD  → "To email" = support@iopresto.com (usato da GitHub Actions via secret)
# 4. Vai in Account > API Keys e copia la Public Key
NUXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx_test       # locale → test
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID_PROD=template_xxxxxxx_prod  # riferimento → va in GitHub Secrets come EMAILJS_TEMPLATE_ID_PROD
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx
