# EmailJS — https://www.emailjs.com/
# 1. Registrati su emailjs.com (gratuito, 200 email/mese)
# 2. Crea un Service (es. Gmail) e copia il Service ID
# 3. Crea un Template con le variabili elencate in emailjs-template.txt e copia il Template ID
# 4. Vai in Account > API Keys e copia la Public Key
NUXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxx

# Google Maps Places API — https://console.cloud.google.com/
# Abilita "Places API" e "Maps JavaScript API" e crea una chiave API
NUXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
